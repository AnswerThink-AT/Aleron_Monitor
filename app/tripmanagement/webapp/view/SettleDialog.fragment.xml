<!-- webapp/view/SettleDialog.fragment.xml -->
<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog id="settleDlg"
          title="Settle Journal Entries"
          contentWidth="60rem"
          resizable="true"
          stretchOnPhone="true"
          class="sapUiResponsiveContentPadding">

    <content>
      <VBox id="_IDGenVBox8" width="100%">

        <!-- Header / progress text -->
        <HBox id="_IDGenHBox2" alignItems="Center" class="sapUiSmallMarginBottom">
          <Text id="_IDGenText12" text="Overall progress" />
          <ToolbarSpacer id="_IDGenToolbarSpacer3"/>
          <Text id="_IDGenText35" text="{parts:['settle>/completed','settle>/total'],
                        formatter:'.formatter.settleProgressText'}"/>
        </HBox>

        <!-- Progress bar -->
        <ProgressIndicator id="_IDGenProgressIndicator"
          width="100%"
          showValue="true"
          percentValue="{parts:['settle>/completed','settle>/total'],
                         formatter:'.formatter.settlePercent'}"
          displayValue="{parts:['settle>/completed','settle>/total'],
                         formatter:'.formatter.settleDisplayValue'}"
          state="{parts:['settle>/completed','settle>/total','settle>/items'],
                  formatter:'.formatter.settleProgressState'}"
          class="sapUiSmallMarginBottom"/>

        <!-- Status counters -->
        <Toolbar id="_IDGenToolbar" class="sapUiTinyMarginTop sapUiTinyMarginBottom" width="100%">
          <Text id="_IDGenText36" text="Selected Trips"/>
          <ToolbarSpacer id="_IDGenToolbarSpacer4"/>
          <!-- Bind to both items and completed to re-evaluate after each update -->
          <ObjectStatus id="_IDGenObjectStatus"
            text="{parts:['settle>/items','settle>/completed'],
                   formatter:'.formatter.countPendingText'}"
            state="Information" icon="sap-icon://pending"/>
          <ObjectStatus id="_IDGenObjectStatus3"
            text="{parts:['settle>/items','settle>/completed'],
                   formatter:'.formatter.countSuccessText'}"
            state="Success" icon="sap-icon://accept"/>
          <ObjectStatus id="_IDGenObjectStatus4"
            text="{parts:['settle>/items','settle>/completed'],
                   formatter:'.formatter.countErrorText'}"
            state="Error" icon="sap-icon://message-error"/>
        </Toolbar>

        <!-- Results table -->
        <Table id="settleTable"
               inset="false"
               growing="true"
               growingScrollToLoad="true"
               width="100%"
               items="{settle>/items}">
          <columns>
            <Column id="_IDGenColumn15" width="8rem"><Text id="_IDGenText37" text="Trip #"/></Column>
            <Column id="_IDGenColumn16" width="12rem"><Text id="_IDGenText38" text="Status"/></Column>
            <Column id="_IDGenColumn17"><Text id="_IDGenText39" text="Details"/></Column>
          </columns>

          <items>
            <ColumnListItem id="_IDGenColumnListItem3" type="Inactive" vAlign="Middle">
              <cells>
                <!-- Trip # -->
                <ObjectIdentifier id="_IDGenObjectIdentifier" title="{settle>TripNumber}"/>

                <!-- Status -->
                <ObjectStatus id="_IDGenObjectStatus5"
                  text="{settle>status}"
                  state="{path:'settle>status', formatter:'.formatter.statusState'}"
                  icon="{path:'settle>status', formatter:'.formatter.statusIcon'}"/>

                <!-- Message -->
                <HBox id="_IDGenHBox3">
                  <!-- <Icon id="_IDGenIcon" visible="{path:'settle>status', formatter:'.formatter.isError'}"
                        src="sap-icon://message-error"/> -->
                  <Text id="_IDGenText40" text="{settle>message}" wrapping="true" maxLines="2" class="sapUiTinyMarginBegin"/>
                </HBox>
              </cells>
            </ColumnListItem>
          </items>
        </Table>

      </VBox>
    </content>

    <beginButton>
      <Button id="_IDGenButton15" text="Close"
              enabled="{= ${settle>/completed} === ${settle>/total} }"
              press=".onSettleDialogClose"/>
    </beginButton>
  </Dialog>
</core:FragmentDefinition>
