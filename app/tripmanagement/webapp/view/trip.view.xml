<mvc:View controllerName="tripmanagement.controller.tripmanagement" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:m="sap.m" xmlns:f="sap.f" xmlns:fb="sap.ui.comp.filterbar" xmlns:svm="sap.ui.comp.smartvariants" xmlns:core="sap.ui.core">
	<Page id="page" >
		<content>
			<f:DynamicPage id="_IDGenDynamicPage" headerExpanded="{/headerExpanded}">
				<f:title>
					<f:DynamicPageTitle id="_IDGenDynamicPageTitle">
						<f:heading>
							<svm:SmartVariantManagement id="svm" showExecuteOnSelection="true"/>
						</f:heading>
						<f:expandedContent>
							<Label id="expandedLabel" text="No filters active"/>
						</f:expandedContent>
						<f:snappedContent>
							<Label id="snappedLabel" text="No filters active"/>
						</f:snappedContent>
					</f:DynamicPageTitle>
				</f:title>
				<f:header>
					<f:DynamicPageHeader id="_IDGenDynamicPageHeader">
						<f:content>
							<fb:FilterBar id="filterbar" persistencyKey="TripReportFilter" useToolbar="false" search=".onSearch" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad">
                                    <!--Personnel-->
									<fb:filterGroupItems>
										<fb:FilterGroupItem id="filterPersonnel" name="Personnel" label="Personnel" groupName="General" visibleInFilterBar="true">
										<fb:control>
											<MultiInput id="miFilterPersonnel" showValueHelp="true" valueHelpRequest="onOpenPersonnelValueHelp" placeholder="Select personnel" suggest="onPersonnelFilterSearch"
												showSuggestion="true"
												tokenUpdate="onPersonnelTokensChanged"
												suggestionItems="{suggest>/items}"
												>
												<suggestionItems>
													<core:ListItem id="_IDGenListItem1"  text="{suggest>PersonFullName}" additionalText="{suggest>PersonExternalID}" />
												</suggestionItems>
												</MultiInput>
										</fb:control>
									</fb:FilterGroupItem>
									<!-- Project -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem4" name="Project" label="Project" groupName="General" visibleInFilterBar="true">
										<fb:control>
											<MultiInput id="_IDGenMultiInput" showValueHelp="true" tokenUpdate="onProjectTokensChanged" valueHelpRequest="onFilterProjectValueHelp" placeholder="Select project"/>
										</fb:control>
									</fb:FilterGroupItem>
									<!-- Trip Number -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem" name="TripNumber" label="Trip Numbers" groupName="General" visibleInFilterBar="true">
										<fb:control>
											<Input id="_IDGenInput" name="TripNumber" value="{filters>/TripNumber}" placeholder="Enter trip number"/>
										</fb:control>
									</fb:FilterGroupItem>
									<!-- Trip Start Date -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem1" name="TripStartDate" label="Trip Start Date" groupName="General" visibleInFilterBar="false">
										<fb:control>
											<DatePicker id="_IDGenDatePicker0" value="{filters>/TripStartDate}" displayFormat="yyyy-MM-dd" placeholder="Select start date"/>
										</fb:control>
									</fb:FilterGroupItem>
									<!-- Trip End Date -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem2" name="TripEndDate" label="Trip End Date" groupName="General" visibleInFilterBar="false">
										<fb:control>
											<DatePicker id="_IDGenDatePicker1" value="{filters>/TripEndDate}" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" placeholder="Select end date"/>
										</fb:control>
									</fb:FilterGroupItem>
									<!-- Destination -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem8" name="Destination" label="Destination" groupName="General" visibleInFilterBar="false">
										<fb:control>
											<MultiComboBox id="_IDGenMultiComboBox1" name="Destination" selectionChange=".onSelectionChange" items="{
                          path: '/Destinations',
                          templateShareable: true
                        }">
												<core:Item id="_IDGenItem" key="{DestID}" text="{DestName}"/>
											</MultiComboBox>
										</fb:control>
									</fb:FilterGroupItem>
									<!-- Trip Status -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem5" name="TripStatus" label="Trip Status" groupName="General" visibleInFilterBar="true">
										<fb:control>
											<MultiComboBox
											id="_IDGenMultiComboBox3"
											items="{tripStatus>/TripStatusLists}"
											selectionChange="onTripStatusChange"
											placeholder="Select Trip Status">
											<core:Item id="_IDGenItem1" key="{tripStatus>name}" text="{tripStatus>name}" />
											</MultiComboBox>
										</fb:control>
										</fb:FilterGroupItem>

									<!-- NEW: Editing Status (hidden until user adds it) -->
									<fb:FilterGroupItem id="_IDGenFilterGroupItem6" name="EditingStatus" label="Editing Status" groupName="General" visibleInFilterBar="false">
										<fb:control>
											<MultiComboBox id="_IDGenMultiComboBox4" name="EditingStatus" selectionChange=".onSelectionChange" items="{ path: '/EditingStatuses', templateShareable: true }">
												<core:Item id="_IDGenItem3" key="{StatusID}" text="{StatusText}"/>
											</MultiComboBox>
										</fb:control>
									</fb:FilterGroupItem>
								</fb:filterGroupItems>
							</fb:FilterBar>
						</f:content>
					</f:DynamicPageHeader>
				</f:header>
				<f:content>
					<Table id="table" inset="false" items="{ path: '/TripReport'}" showOverlay="false" mode='MultiSelect' alternateRowColors="true" growing="true"
                            growingThreshold="20"
                            growingScrollToLoad="false"
                            selectionChange="onChangeSelection"
                            updateStarted="onUpdateStarted"
                            updateFinished="onUpdateFinished">
						<!-- 1) Use headerToolbar, NOT toolbar -->
						<headerToolbar>
							<OverflowToolbar id="_IDGenOverflowToolbar">
							    <Title id="tripTableTitle" text="Trips" level="H4"/>
								<ToolbarSpacer id="_IDGenToolbarSpacer"/>
								<!-- 2) Your CRUD buttons go first (left-aligned) -->
								<Button id="_IDGenButton1" text="Create" icon="sap-icon://add" press=".onCreate"/>
								<Button id="_IDGenButton2" text="Cancel" icon="sap-icon://decline" press=".onCancel"/>
								<Button id="_IDGenButton3" text="Settle" icon="sap-icon://accept" press=".onSettle"/>
								<Button id="_IDGenButton4" text="Delete" icon="sap-icon://delete" press=".onDelete"/>
								<!-- 4) Settings (column chooser) -->
								<Button id="_IDGenButton5" icon="sap-icon://action-settings" tooltip="Choose columns" press=".onPersonalizeColumns"/>
								<!-- 5) Export to Excel -->
								<Button id="_IDGenButton6" icon="sap-icon://excel-attachment" tooltip="Export to Excel" press=".onExportToExcel"/>
							</OverflowToolbar>
						</headerToolbar>
						<columns>
							<Column id="_IDGenColumn" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText1" text="Trip Number"/>
							</Column>
							<Column id="_IDGenColumn14" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText30" text="Personnel"/>
								</Column>
							<Column id="_IDGenColumn1" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText2" text="Start Date"/>
							</Column>
							<Column id="_IDGenColumn2" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText3" text="End Date"/>
							</Column>
							<Column id="_IDGenColumn3" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText4" text="Project"/>
							</Column>
							<Column id="_IDGenColumn4" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText5" text="Destination"/>
							</Column>
							<Column id="_IDGenColumn5" minScreenWidth="Tablet" demandPopin="true">
								<Text id="_IDGenText6" text="Status"/>
							</Column>
							<Column id="ChangedOnCol" visible="false">
								<Text id="_IDGenText13" text="Changed On"/>
							</Column>
							<Column id="ChangedByCol" visible="false">
								<Text id="_IDGenText14" text="Changed By"/>
							</Column>
							<Column id="CreatedOnCol" visible="false">
								<Text id="_IDGenText15" text="Created On"/>
							</Column>
							<Column id="CreatedByCol" visible="false">
								<Text id="_IDGenText16" text="Created By"/>
							</Column>
						</columns>
						<items>
							<ColumnListItem id="_IDGenColumnListItem" vAlign="Middle" type="Navigation" press=".onListItemPress">
								<cells>
									<Text id="_IDGenText7" text="{TripNumber}"/>
									<Text id="_IDGenText29" text="{Personnel}" visible="true"/>
									<Text id="_IDGenText8" text="{TripStartDate}"/>
									<Text id="_IDGenText9" text="{TripEndDate}"/>
									<Text id="_IDGenText10" text="{ProjectName}"/>
									<Text id="_IDGenText11" text="{DestinationName}"/>
									<m:ObjectStatus id="_IDGenObjectStatus2" text="{StatusText}" state="{ path: 'StatusText', formatter: '.formatter.statusStateFromText' }"/>
									<Text id="_IDGenText18" text="{ModifiedAt}" visible="{path:'ChangedOnCol',formatter:'.formatter.visible'}"/>
									<!-- rename ChangedBy → ModifiedBy -->
									<Text id="_IDGenText19" text="{ModifiedBy}" visible="{path:'ChangedByCol',formatter:'.formatter.visible'}"/>
									<!-- rename CreatedOn → CreatedAt -->
									<Text id="_IDGenText20" text="{CreatedAt}"  visible="{path:'CreatedOnCol',formatter:'.formatter.visible'}"/>
									<!-- CreatedBy stays the same -->
									<Text id="_IDGenText31" text="{CreatedBy}"  visible="{path:'CreatedByCol',formatter:'.formatter.visible'}"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</f:content>
			</f:DynamicPage>
		</content>
	</Page>
</mvc:View>
