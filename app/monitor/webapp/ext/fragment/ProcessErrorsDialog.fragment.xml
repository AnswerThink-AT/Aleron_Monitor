<core:FragmentDefinition xmlns:unified="sap.ui.unified"
	xmlns:core="sap.ui.core"
	xmlns="sap.m">
	<Dialog core:require="{ handler: 'monitor/ext/controller/CustomAction' }"
		title="Process Errors"
		verticalScrolling="true"
		contentHeight="150px"
		contentWidth="1600px">
		<content>
		<Table
			id="idProcessLogsTable"
			items="{/ProcessLogs}"
			inset="false"
			enableBusyIndicator="true"
			growing="true"
			noDataText="No Logs found">

			<columns>
				<Column>
					<Text text="Process Code"/>
				</Column>
				<Column>
					<Text text="Status" />
				</Column>
				<Column>
					<Text text="Message"/>
				</Column>
			</columns>

			<items>
				<ColumnListItem>
					<cells>
						<Text text="{
  parts: [
    { path: 'process_code' },
    { path: 'ui>/interfaceTypeId' }
  ],
  formatter: 'handler.formatProcessCodeLabel'
}"/>

						<ObjectStatus 
							text="{path: 'type_code', formatter: 'handler.formatTypeLabel'}"
							state="{path: 'type_code', formatter: 'handler.formatTypeState'}"
						/>

						<Text text="{message}" wrapping="true"/>
					</cells>
				</ColumnListItem>
			</items>

		</Table>
		</content>
		<beginButton>
			<Button text="Ok"
				type="Default"
				press="handler.onProcessErrorsOK"/>
		</beginButton>
	</Dialog>
</core:FragmentDefinition>