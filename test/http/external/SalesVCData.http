###
# Environment should be switched by commenting either BAS environment or Local VSCode environment. Make sure to comment the other environment.
# Region for comment would be - Start to - End

### BAS environment -- Start
@s4_base_url=http://S4HC_MONITOR_BASIC_AUTH_CUST.dest
@default_headers=Content-Type: application/json
@Accept=Accept: application/json


@svc_url_v1={{s4_base_url}}/sap/opu/odata/sap/YY1_SALESVCDATA_1_CDS
@svc_url_v2={{s4_base_url}}/sap/opu/odata/sap/YY1_SALESVCDATA_2_CDS

@svc=http://localhost:4004/odata/v4/monitor

### V1 metadata call
# @name metadata_call_V1

GET {{svc_url_v1}}/$metadata
{{default_headers}}
X-CSRF-Token: Fetch

### V2 metadata call
# @name metadata_call_V2

GET {{svc_url_v2}}/$metadata
{{default_headers}}
X-CSRF-Token: Fetch

###
@csrf_token_v1={{metadata_call_V1.response.headers.X-CSRF-Token}}
@csrf_token_v2={{metadata_call_V2.response.headers.X-CSRF-Token}}

### Get Sales VC DATA V1 
GET {{svc_url_v1}}/YY1_SALESVCDATA_1
?$filter=SalesOrderNumber eq '2700003985'
{{default_headers}}
{{Accept}}

### Get Sales VC DATA V2 
GET {{svc_url_v2}}/YY1_SALESVCDATA_2
?$filter=Sales_Order_Number eq '2700000085'
{{default_headers}}
{{Accept}}

