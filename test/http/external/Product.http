### BAS environment -- Start
@s4_base_url=http://S4HC_MONITOR_BASIC_AUTH_CUST.dest
@default_headers=Content-Type: application/json
@Accept=Accept: application/json


@svc_url={{s4_base_url}}/sap/opu/odata/sap/API_PRODUCT_SRV
@svc=http://localhost:4004/odata/v4/monitor

# @name metadata_call

GET {{svc_url}}/$metadata
{{default_headers}}
X-CSRF-Token: Fetch

###
@csrf_token={{metadata_call.response.headers.X-CSRF-Token}}

### GET SalesOrderPartner - ZR
GET {{svc_url}}/A_ProductSalesDelivery
?$filter=Product eq '100000511' and ProductSalesOrg eq '' and ProductDistributionChnl eq '01'
{{default_headers}}