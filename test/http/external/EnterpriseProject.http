###
# Environment should be switched by commenting either BAS environment or Local VSCode environment. Make sure to comment the other environment.
# Region for comment would be - Start to - End

### BAS environment -- Start
@s4_base_url=http://S4HC_MONITOR_BASIC_AUTH_CUST.dest
@default_headers=Content-Type: application/json
### BAS environment -- End

### Local VSCode environment - Start
# @s4_user={{$dotenv s4_user}}
# @s4_pass={{$dotenv s4_pass}}
# @s4_base_url=https://my420210-api.s4hana.cloud.sap
# @basic_auth=Authorization: Basic {{s4_user}}:{{s4_pass}}
# @default_headers=Content-Type: application/json\n{{basic_auth}}
### Local VSCode environment - End

# Service Variables
@svc_url={{s4_base_url}}/sap/opu/odata/sap/API_ENTERPRISE_PROJECT_SRV;v=0002
@svc=http://localhost:4004/odata/v4/monitor

@default_headers=Content-Type: application/json
### Metadata
# @name metadata_call
 
GET {{svc_url}}/$metadata
{{default_headers}}
X-CSRF-Token: Fetch
 
###
@csrf_token={{metadata_call.response.headers.X-CSRF-Token}}

### Get Enterprise Project
GET {{svc_url}}/A_EnterpriseProject
?$top=1
{{default_headers}}

### Get Enterprise Project
GET {{svc_url}}/ChangeEntProjProcgStatus?ProjectUUID=guid'25fae728-ea6c-1fd0-88c2-55822b705ae5'
{{default_headers}}

### Get Enterprise Project
POST {{svc_url}}/ChangeEntProjProcgStatus?ProjectUUID=guid'25fae728-ea6c-1fd0-88c2-55822b705ae5'&ProcessingStatus='10'  
Content-Type: application/json
X-CSRF-Token: {{csrf_token}}
If-Match: *




### Get Enterprise Project
GET {{svc_url}}/A_EnterpriseProject
# ?$select=Project
# &$orderby=CreationDateTime desc
&$top=1
# ?$filter=Project eq '4400000062'
{{default_headers}}

### Update call
PATCH {{svc_url}}/A_EnterpriseProject(guid'25fae728-ea6c-1fd0-88be-95f4d1c09ae5')
Content-Type: application/json
X-CSRF-Token: {{csrf_token}}
If-Match: *

{   
    "Project": "4400000062"
}
