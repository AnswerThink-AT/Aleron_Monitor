### EmployeeHires
POST {{svc}}/Files
Content-Type: application/json

<@ ./EmployeeHires.json


###

GET http://S4HC_MONITOR_BASIC_AUTH_CUST.dest/sap/opu/odata4/sap/api_salesorder/srvd_a2x/sap/salesorder/0001/SalesOrder


###

GET http://S4HC_MONITOR_BASIC_AUTH_CUST.dest/sap/opu/odata/sap/YY1_SALESVCDATA_2_CDS/$metadata

###

GET {{svc}}/EmployeeHires
?$filter=valid eq 'true' and processLevel_code eq '1'



### Employee Hire T flow

### Create File with EmployeeHires
# @name create_employeehire_call
POST {{svc}}/Files
{{default_headers}}

# <@ ./payloads/EmployeeHires_Create_WithProject.json
# <@ ./payloads/EmployeeHires_Create_Invalid.json
<@ ./payloads/EmployeeHires_Create.json


###
@createdFileID={{create_employeehire_call.response.body.ID}}
@firstRecordID={{create_employeehire_call.response.body.to_EmployeeHires[0].ID}}
# @createdFileID=218
# @firstRecordID="d9af7eaf-7b3a-4bfa-a61b-9b6976531bc1"


### Reset file to initial state
# PATCH {{svc}}/Files(ID={{createdFileID}},IsActiveEntity=true)
PATCH {{svc}}/Files(ID={{createdFileID}},IsActiveEntity=true)
{{default_headers}}

{
  "status_code": 1
}

### Process File - Action call
POST {{svc}}/processFile
{{default_headers}}

{
  "fileNumber": "{{createdFileID}}",
  "records":[
  ],
  "from": "-1"
}

### Process Records - Action call
POST {{svc}}/processFile
{{default_headers}}

{
  "fileNumber": "{{createdFileID}}",
  "records":[
    "{{firstRecordID}}"
  ],
  "from": "2"
}


### validate

POST {{svc}}/validateFile
Content-Type: application/json

{
  "fileNumber": "{{createdFileID}}",
  "records": [
    "{{firstRecordID}}"
  ]
}

### Update EmployeeHires - Intergration Step
POST {{svc}}/updateRecords
{{default_headers}}

{
  "interfaceType": "T",
  "records" : [
    {
      "ID": "{{firstRecordID}}",
      "file_ID": "{{createdFileID}}",
      "valid": true,
      "processLevel_code": "2",
      "personnelNoSAP": "10000103"
    }
  ]
}


###


### Files > EmployeeHires
GET {{svc}}/Files
?$filter=ID eq '{{createdFileID}}'
&$expand=to_EmployeeHires($select=contractNo,processLevel_code,projectNumberSAP,valid,personnelNoSAP,salesDocumentNoSAP,salesItemNoSAP)

###

GET {{svc}}/ProcessLogs
?$select=ID,IsActiveEntity,message
&$filter=record_ID eq '{{firstRecordID}}'
&$skip=0
&$top=100

###

GET {{svc}}/ProcessLogs
?$select=ID
&$filter=record_ID eq '3ed75c7e-0c2b-41d9-8208-27baee84604e'

