@svc = http://localhost:4004/odata/v4/monitor
@default_headers=Content-Type: application/json

### Files
GET {{svc}}/$metadata

### Files
# @name Files_GET
GET {{svc}}/Files
?$filter=ID eq '1025'
&$expand=to_SowScInvoice
# ?$expand=to_Times


### Files Drafts GET
# @name Files_Drafts_GET
GET {{svc}}/Files?$filter=(IsActiveEntity eq false)



### Files Draft POST
# @name Files_Draft_POST
POST {{svc}}/Files
Content-Type: application/json


{
  "name": "name-8945474",
  "type": "csv",
  "status": {
    "code": 1
  },
  "interfaceType": {
    "ID": "3"
  },
  "source": "LOCAL",
  "recordsCount": 2,
  "reprocessed": true,
  "processMessage": "processMessage-8945474",
  "processLevel": {
    "code": "0"
  }
}


### Result from POST request above
@draftID = {{Files_Draft_POST.response.body.$.ID}}


### Files Draft PATCH
# @name Files_Draft_Patch
PATCH {{svc}}/Files(ID={{draftID}},IsActiveEntity=false)
Content-Type: application/json


{
  "HasActiveEntity": true
}


### Files Draft Prepare
# @name Files_Draft_Prepare
POST {{svc}}/Files(ID={{draftID}},IsActiveEntity=false)/MonitorService.draftPrepare
Content-Type: application/json


{}


### Files Draft Activate
# @name Files_Draft_Activate
POST {{svc}}/Files(ID={{draftID}},IsActiveEntity=false)/MonitorService.draftActivate
Content-Type: application/json


{}


